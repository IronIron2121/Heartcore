{
  "name": "Heartcore",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "$path": "src/repstore"
    },

    "ServerScriptService": {
      "$className": "ServerScriptService",

      "ServerCustomisationServer": {
        "$path": "src/server/Player/ServerCustomisationServer.server.lua"
      },

      "ServerOutfitService": {
        "$path": "src/server/Player/ServerOutfitService.server.lua"
      }
    },

    "StarterPlayer": {
      "$className": "StarterPlayer",

      "StarterPlayerScripts": {
        "$className": "StarterPlayerScripts",

        "Clothing": {
          "$className": "Folder",

          "ClientCustomisationService": {
            "$path": "src/client/Clothing/ClientCustomisationService.luau"
          }
        },

        "GUI": {
          "$className": "Folder",

          "GuiManager": {
            "$className": "Folder",

            "InitialiseGuiManager": {
              "$path": "src/client/GUI/GuiManager/InitialiseGuiManager.client.luau"
            }
          }
        },

        "Mannequins": {
          "$className": "Folder",

          "Inspector": {
            "$path": "src/client/Mannequins/Inspector"
          }
        }
      }
    },

    "Lighting": {
      "$properties": {
        "Ambient": [
          0,
          0,
          0
        ],
        "Brightness": 2,
        "GlobalShadows": true,
        "Outlines": false,
        "Technology": "Voxel"
      }
    },

    "SoundService": {
      "$properties": {
        "RespectFilteringEnabled": true
      }
    }
  }
}
